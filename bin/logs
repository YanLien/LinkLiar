#!/bin/sh
# Stream LinkLiar logs with color-coded output (daemon=blue, gui=red)

BLUE='\033[1;34m'
RED='\033[1;31m'
NC='\033[0m'

/usr/bin/log stream --style json \
  --predicate 'subsystem == "io.github.halo.LinkLiar"' \
  --level debug 2>/dev/null | while IFS= read -r line; do
    msg=$(echo "$line" | grep -o '"eventMessage"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*: *"//;s/"$//')
    [ -z "$msg" ] && continue

    if echo "$line" | grep -q 'linkdaemon'; then
        printf "${BLUE}Daemon${NC} - %s\n" "$msg"
    else
        printf "${RED}GUI${NC}    - %s\n" "$msg"
    fi
done
